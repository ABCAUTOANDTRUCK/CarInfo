<!DOCTYPE html>
<html>
<head>
    <title>My Search Database</title>

    <style>
        body{
            font-family:Arial;
            background:#f2f2f2;
            text-align:center;
            padding:50px;
        }

        input{
            width:300px;
            padding:10px;
            font-size:18px;
        }

        button{
            padding:10px 20px;
            font-size:18px;
            cursor:pointer;
        }

        #result{
            margin-top:40px;
            background:white;
            padding:20px;
            border-radius:10px;
            max-width:700px;
            margin-left:auto;
            margin-right:auto;
            text-align:left;
        }
    </style>
</head>

<body>

<h1>Search</h1>

<input id="searchBox" placeholder="Search...">
<button onclick="search()">Search</button>

<div id="result"></div>

<script>

const database = {

    "dragon":{
        title:"Dragon",
        info:"Dragons are giant flying creatures that breathe fire."
    },

    "fireball":{
        title:"Fireball",
        info:"A powerful spell that launches a ball of fire."
    },

    "sword":{
        title:"Sword",
        info:"A melee weapon used by knights and warriors."
    }

};

function search(){

    let word = document.getElementById("searchBox").value.toLowerCase().trim();

    if(database[word]){

        document.getElementById("result").innerHTML = `
            <h2>${database[word].title}</h2>
            <p>${database[word].info}</p>
        `;

    }

    else{

        document.getElementById("result").innerHTML =
        "<h2>Nothing found.</h2>";

    }

}

document.getElementById("searchBox").addEventListener("keypress",function(event){

    if(event.key==="Enter"){
        search();
    }

});

</script>

</body>
</html>
